# Application
APP_ENV=local
LOG_LEVEL=INFO

# Database (SQLite v1 -> Postgres later via SQLAlchemy, Section 8.1)
DATABASE_URL=sqlite:///./data/hr_assistant.db

# CORS (comma-separated origins) - only relevant for local dev, where the
# Vite dev server (port 5173) and the API (port 8000) are different
# origins. Unused in the Railway single-service deployment (ADR-011,
# docs/DEPLOYMENT.md): FastAPI serves the built SPA itself, so every
# request is same-origin and this var can be left unset.
CORS_ORIGINS=http://localhost:5173

# Upload limits (FR-D01, FR-D02, FR-D03)
UPLOAD_MAX_FILE_MB=25
UPLOAD_MAX_FILES=10

# Rate limiting - edge tier (Section 11.6)
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_WINDOW_SECONDS=60

# Retrieval & ranking (SDD Section 6.3.3/6.3.4, 7.2 Stage 7-8)
# Values calibrated from real measurement, not the SDD's illustrative
# "~0.35" - see docs/threshold-calibration.md and
# scripts/calibrate_threshold.py.
RETRIEVAL_TOP_K=8
RETRIEVAL_SIMILARITY_THRESHOLD=0.50
RETRIEVAL_HIGH_CONFIDENCE_THRESHOLD=0.65
CONTEXT_TOKEN_BUDGET=2000
CONTEXT_MAX_BLOCKS=4
MMR_LAMBDA=0.5

# Response validation groundedness (SDD Section 6.3.7) - calibrated, see
# docs/threshold-calibration.md ("Model swap re-run") and
# scripts/calibrate_threshold.py --live. Re-run after any future model
# swap or fixture change.
GROUNDEDNESS_REJECT_THRESHOLD=0.10
GROUNDEDNESS_COMFORTABLE_THRESHOLD=0.13

# Prompt building (SDD Section 6.3.5, 7.2 Stage 9)
PROMPT_TOKEN_BUDGET=2400

# Sessions (FR-S06)
SESSION_TTL_HOURS=24

# Conversation memory (SDD Section 6.3.9, FR-S05)
MEMORY_WINDOW_TURNS=6
MEMORY_SUMMARY_REFRESH_INTERVAL_TURNS=6

# LLM / Gemini (SDD Section 6.3.6) - required for real /chat generation;
# unit tests use a fake adapter and never need a real key.
# GEMINI_MODEL_NAME: if generation starts failing with a 404, the
# configured model was likely retired - see README "Troubleshooting".
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-3.5-flash
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_OUTPUT_TOKENS=1024
# Real gemini-3.5-flash calls have been observed taking ~19-30s; 20s left
# too little margin (see docs/threshold-calibration.md "Model swap
# re-run"). Re-measure with `python scripts/calibrate_threshold.py --live`
# after any future model swap.
GEMINI_TIMEOUT_SECONDS=45
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_DELAY_SECONDS=1.0
GEMINI_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
GEMINI_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30

# Middleware seams (Section 5.3, 6.3.1) - rarely need overriding
REQUEST_ID_HEADER=X-Request-ID
AUTH_HEADER_NAME=X-User-Id

# Static frontend serving (ADR-011, docs/DEPLOYMENT.md) - leave unset for
# local dev (the Vite dev server owns frontend serving); the Dockerfile
# sets this to /app/frontend_dist in the Railway deployment image so
# FastAPI serves the built SPA itself.
# FRONTEND_DIST_DIR=

# Demo document seeding (ADR-012, docs/DEPLOYMENT.md) - leave unset
# (defaults false) for local dev/tests. The Hugging Face Space sets this
# true: its free-tier storage is ephemeral (resets on every restart), so
# a bundled sample PDF re-ingests itself on cold start whenever the
# tenant has no documents yet.
# SEED_DEMO_DOCUMENT=

# Default tenant/user seed (single-tenant v1, ADR-007) - rarely need overriding
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_TENANT_NAME=Default Tenant
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000002
DEFAULT_USER_EMAIL=admin@example.com
DEFAULT_USER_DISPLAY_NAME=Default Admin
