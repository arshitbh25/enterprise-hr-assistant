# Base URL for the backend API. Defaults to '/api/v1' (routed through the
# Vite dev server proxy to http://localhost:8000 - see vite.config.ts), so
# this only needs setting for a non-proxied/production deployment.
VITE_API_BASE_URL=/api/v1

# Client-side upload pre-checks (UploadDropzone) - must match the backend's
# UPLOAD_MAX_FILE_MB / UPLOAD_MAX_FILES (see backend/.env.example) or users
# will see a client-side rejection the server would have accepted, or vice
# versa. Optional: defaults to 25 / 10 if unset.
VITE_MAX_FILE_MB=25
VITE_MAX_FILES=10
